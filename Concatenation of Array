class Solution {
    public int[] getConcatenation(int[] nums) {
        int n =nums.length;
        int index=0;
        int res[]=new int [n+n];
        for(int i =0;i<n;i++){
            res[i]=nums[i];
            index++;
        }
        int j=0;
        for(int i =index;i<res.length;i++){
            res[i]=nums[j++];
        }
        return res;
    }
}
